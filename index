<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elevare Portfolio</title>
    <style>
        /* 1. Resetting the page */
        body, html { 
            margin: 0; 
            padding: 0; 
            height: 100%; 
            overflow: hidden; 
            background-color: #636363; /* Matches the gray background of the flipbook */
        }

        /* 2. Full-screen container */
        .wrapper {
            position: relative;
            width: 100%;
            height: 100vh;
        }

        /* 3. The Flipbook */
        iframe {
            border: none;
            width: 100%;
            height: 100%;
        }

        /* 4. The Masking Shape */
        .mask {
            position: absolute;
            bottom: 30px;    /* Moves it up from the bottom edge */
            left: 20px;      /* Moves it in from the left edge */
            width: 160px;    /* Width to cover the logo */
            height: 80px;    /* Height to cover the logo */
            background-color: #636363; /* Same as background to blend in */
            z-index: 100;    /* Ensures it stays on top of the iframe */
            border-radius: 4px; /* Optional: smooths the edges */
            pointer-events: none; /* Allows you to still click "through" it if needed */
        }

        /* 5. Optional Text for the Mask */
        .mask-content {
            color: #ffffff;
            font-family: Arial, sans-serif;
            font-size: 11px;
            letter-spacing: 1px;
            text-align: center;
            line-height: 80px;
            opacity: 0.4;
        }
    </style>
</head>
<body>

    <div class="wrapper">
        <iframe src="https://heyzine.com/flip-book/1f268b08d8.html" allowfullscreen></iframe>

        <div class="mask">
            <div class="mask-content">ELEVARE</div>
        </div>
    </div>

</body>
</html>
